    pointer-events: none;
  }

  .cell.conflict .queen-mark {
    color: #ff3333;
    animation: shake 0.3s ease-in-out;
  }

  .cell.conflict {
    box-shadow: inset 0 0 0 3px rgba(255, 50, 50, 0.7);
  }

  /* Region border rendering */
  .cell.border-top { border-top: 3px solid #333; }
  .cell.border-bottom { border-bottom: 3px solid #333; }
  .cell.border-left { border-left: 3px solid #333; }
  .cell.border-right { border-right: 3px solid #333; }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-3px); }
    75% { transform: translateX(3px); }
  }

  .win-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    display: flex;
