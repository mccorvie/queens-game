<body>

<h1>QUEENS</h1>
<p class="subtitle">Place a queen in every row, column, and color region</p>

<div class="puzzle-selector">
  <label for="size-filter">Size:</label>
  <select id="size-filter"></select>
  <label class="toggle">
    <input type="checkbox" id="chk-shuffle">
    Randomize
  </label>
  <button id="btn-prev" title="Previous puzzle">&lsaquo;</button>
  <select id="puzzle-select"></select>
  <button id="btn-next" title="Next puzzle">&rsaquo;</button>
</div>

<div class="toolbar">
  <span class="timer" id="timer">0:00</span>
</div>

<div class="board-container">
  <div class="board" id="board"></div>
</div>

<div class="progress" id="progress"></div>

<div class="toolbar">
  <button id="btn-undo" title="Undo (Ctrl+Z)">Undo</button>
  <button id="btn-reset">Reset</button>
  <label class="toggle">
    <input type="checkbox" id="chk-autox" checked>
    Auto-X
  </label>
</div>

<div class="win-overlay" id="win-overlay">
  <div class="win-box">
    <h2>Congratulations!</h2>
    <p class="win-time" id="win-time"></p>
    <button id="btn-next-puzzle">Next Puzzle</button>
  </div>
</div>

<script src="puzzles.js"></script>
<script>
// ============================================================
// PUZZLE NAMING
// ============================================================
// Anchor: puzzle #655 = 2026-02-14
const ANCHOR_NUMBER = 655;
const ANCHOR_DATE = new Date(2026, 1, 14); // months are 0-indexed

function puzzleDate(number) {
  const d = new Date(ANCHOR_DATE);
  d.setDate(d.getDate() + (number - ANCHOR_NUMBER));
  return d;
}

function puzzleDisplayName(p) {
  if (p.number != null) {
    const d = puzzleDate(p.number);
    const yyyy = d.getFullYear();
    const mm = String(d.getMonth() + 1).padStart(2, '0');
    const dd = String(d.getDate()).padStart(2, '0');
    return `#${p.number} (${yyyy}-${mm}-${dd})`;
  }
  return p.name || 'Unnamed Puzzle';
}

// Color palette matching the official LinkedIn Queens game
const REGION_COLORS = [
  '#b8a0d4', // purple/lavender
  '#dde34e', // yellow/lime
  '#e8a0be', // pink
  '#a8a068', // olive/brown
  '#dddcda', // light gray
  '#8db4e4', // blue/cornflower
  '#e87050', // red/coral-orange
  '#b8d868', // green/lime-green
  '#f0b878', // orange/peach
  '#85cdca', // teal
  '#d4e09b', // lime
  '#c4b7a6', // tan
];

// ============================================================
// GAME STATE
// ============================================================
let puzzle = null;
let size = 0;
let queens = [];
let manualX = [];
let autoXMap = [];
let history = [];
let timerStart = null;
let timerInterval = null;
let elapsed = 0;
let gameWon = false;
let isDragging = false;
let dragCells = [];
let originalPuzzle = null; // the unmodified PUZZLES entry
let filteredPuzzles = []; // puzzles matching current size filter

function cellState(r, c) {
  if (queens[r][c]) return 'queen';
  if (manualX[r][c] || autoXMap[r][c].size > 0) return 'x';
  return 'empty';
}

// Collect all cells that would be affected by placing/removing a queen at (r,c)
function affectedCells(r, c) {
  const set = new Set();
  set.add(r + ',' + c);
  for (let i = 0; i < size; i++) {
    set.add(r + ',' + i); // same row
    set.add(i + ',' + c); // same col
  }
  const region = puzzle.regions[r][c];
  for (let rr = 0; rr < size; rr++)
    for (let cc = 0; cc < size; cc++)
      if (puzzle.regions[rr][cc] === region) set.add(rr + ',' + cc);
  for (let dr = -1; dr <= 1; dr++)
    for (let dc = -1; dc <= 1; dc++) {
      const nr = r + dr, nc = c + dc;
      if (nr >= 0 && nr < size && nc >= 0 && nc < size) set.add(nr + ',' + nc);
    }
  return [...set].map(s => s.split(',').map(Number));
}

// Snapshot a set of cells for undo
function snapshotCells(cells) {
  return cells.map(([r, c]) => ({
    r, c,
    queen: queens[r][c],
    manual: manualX[r][c],
    autoX: new Set(autoXMap[r][c])
  }));
}

function restoreSnapshot(snap) {
  for (const s of snap) {
    queens[s.r][s.c] = s.queen;
    manualX[s.r][s.c] = s.manual;
    autoXMap[s.r][s.c] = s.autoX;
  }
}

// ============================================================
// INITIALIZATION
// ============================================================
function init() {
  populateSizeFilter();
  applyFilter();

  document.getElementById('btn-undo').addEventListener('click', undo);
  document.getElementById('btn-reset').addEventListener('click', resetBoard);
  document.getElementById('btn-next-puzzle').addEventListener('click', () => {
    document.getElementById('win-overlay').classList.remove('show');
    loadNextPuzzle();
  });
  document.getElementById('btn-next').addEventListener('click', () => loadNextPuzzle());
  document.getElementById('btn-prev').addEventListener('click', () => loadPrevPuzzle());
  document.getElementById('puzzle-select').addEventListener('change', (e) => {
    const idx = parseInt(e.target.value);
    if (!isNaN(idx) && PUZZLES[idx]) loadPuzzle(PUZZLES[idx]);
  });
  document.getElementById('size-filter').addEventListener('change', () => {
    applyFilter();
  });
  document.getElementById('chk-shuffle').addEventListener('change', () => {
    applyFilter();
  });

  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'z') {
      e.preventDefault();
      undo();
    }
  });

  document.addEventListener('mouseup', endDrag);
  document.addEventListener('touchend', endDrag);
}

function populateSizeFilter() {
  const sizes = [...new Set(PUZZLES.map(p => p.size))].sort((a, b) => a - b);
  const sel = document.getElementById('size-filter');
  sel.innerHTML = '';
  const allOpt = document.createElement('option');
  allOpt.value = 'all';
  allOpt.textContent = 'All';
  sel.appendChild(allOpt);
  sizes.forEach(s => {
    const opt = document.createElement('option');
    opt.value = s;
    opt.textContent = s + '\u00d7' + s;
    sel.appendChild(opt);
  });
}

function applyFilter() {
  const filterVal = document.getElementById('size-filter').value;
  if (filterVal === 'all') {
    filteredPuzzles = PUZZLES.map((p, i) => i);
  } else {
    const sz = parseInt(filterVal);
    filteredPuzzles = [];
    PUZZLES.forEach((p, i) => { if (p.size === sz) filteredPuzzles.push(i); });
  }
  if (document.getElementById('chk-shuffle').checked) {
    for (let i = filteredPuzzles.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [filteredPuzzles[i], filteredPuzzles[j]] = [filteredPuzzles[j], filteredPuzzles[i]];
    }
  }
  populatePuzzleSelector();
  if (filteredPuzzles.length > 0) {
    loadPuzzle(PUZZLES[filteredPuzzles[0]]);
  }
}

function populatePuzzleSelector() {
  const sel = document.getElementById('puzzle-select');
  sel.innerHTML = '';
  filteredPuzzles.forEach(idx => {
    const p = PUZZLES[idx];
    const opt = document.createElement('option');
    opt.value = idx;
    opt.textContent = puzzleDisplayName(p);
    sel.appendChild(opt);
  });
}

function loadNextPuzzle() {
  const currentPos = filteredPuzzles.indexOf(PUZZLES.indexOf(originalPuzzle));
  const nextPos = (currentPos + 1) % filteredPuzzles.length;
  loadPuzzle(PUZZLES[filteredPuzzles[nextPos]]);
}

function loadPrevPuzzle() {
  const currentPos = filteredPuzzles.indexOf(PUZZLES.indexOf(originalPuzzle));
  const prevPos = (currentPos - 1 + filteredPuzzles.length) % filteredPuzzles.length;
  loadPuzzle(PUZZLES[filteredPuzzles[prevPos]]);
}

// Apply a random element of D4 (8 symmetries of a square) and a random color permutation
function randomizePuzzle(p) {
  const n = p.size;
  const src = p.regions;
  const sym = Math.floor(Math.random() * 8);

  // Apply symmetry transformation
  const transformed = Array.from({length: n}, () => Array(n).fill(0));
  for (let r = 0; r < n; r++) {
    for (let c = 0; c < n; c++) {
      let nr, nc;
      switch (sym) {
        case 0: nr = r; nc = c; break;             // identity
        case 1: nr = c; nc = n - 1 - r; break;     // 90° CW
        case 2: nr = n - 1 - r; nc = n - 1 - c; break; // 180°
        case 3: nr = n - 1 - c; nc = r; break;     // 270° CW
        case 4: nr = n - 1 - r; nc = c; break;     // reflect horizontal
        case 5: nr = r; nc = n - 1 - c; break;     // reflect vertical
        case 6: nr = c; nc = r; break;              // reflect main diagonal
        case 7: nr = n - 1 - c; nc = n - 1 - r; break; // reflect anti-diagonal
      }
      transformed[nr][nc] = src[r][c];
    }
  }

  // Random permutation of region colors
  const unique = [...new Set(transformed.flat())].sort((a, b) => a - b);
  const shuffled = [...unique];
  for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }
  const colorMap = {};
  unique.forEach((v, i) => { colorMap[v] = shuffled[i]; });

  const finalRegions = transformed.map(row => row.map(v => colorMap[v]));
  return { ...p, regions: finalRegions };
}

function loadPuzzle(p) {
  originalPuzzle = p;
  puzzle = document.getElementById('chk-shuffle').checked ? randomizePuzzle(p) : p;
  size = puzzle.size;
  queens = Array.from({length: size}, () => Array(size).fill(false));
  manualX = Array.from({length: size}, () => Array(size).fill(false));
  autoXMap = Array.from({length: size}, () => Array.from({length: size}, () => new Set()));
  history = [];
  gameWon = false;
  document.getElementById('win-overlay').classList.remove('show');
  // Sync the selector to the current puzzle
  const globalIdx = PUZZLES.indexOf(originalPuzzle);
  document.getElementById('puzzle-select').value = globalIdx;
  stopTimer();
  elapsed = 0;
  updateTimerDisplay();
  timerStart = null;
  buildBoard();
  updateProgress();
}

// ============================================================
// BOARD RENDERING
// ============================================================
function buildBoard() {
  const board = document.getElementById('board');
  board.innerHTML = '';
  board.style.gridTemplateColumns = `repeat(${size}, 1fr)`;

  for (let r = 0; r < size; r++) {
    for (let c = 0; c < size; c++) {
      const cell = document.createElement('div');
      cell.className = 'cell';
      cell.dataset.row = r;
      cell.dataset.col = c;
      cell.style.backgroundColor = REGION_COLORS[puzzle.regions[r][c] % REGION_COLORS.length];

      // Region borders
      const region = puzzle.regions[r][c];
      if (r === 0 || puzzle.regions[r-1][c] !== region) cell.classList.add('border-top');
      if (r === size-1 || puzzle.regions[r+1][c] !== region) cell.classList.add('border-bottom');
      if (c === 0 || puzzle.regions[r][c-1] !== region) cell.classList.add('border-left');
      if (c === size-1 || puzzle.regions[r][c+1] !== region) cell.classList.add('border-right');

      cell.addEventListener('mousedown', (e) => { e.preventDefault(); onCellMouseDown(r, c); });
      cell.addEventListener('mouseenter', (e) => { if (isDragging) onCellDragEnter(r, c); });
      cell.addEventListener('touchstart', (e) => { e.preventDefault(); onCellMouseDown(r, c); }, {passive: false});
      cell.addEventListener('touchmove', (e) => {
        e.preventDefault();
        const touch = e.touches[0];
        const el = document.elementFromPoint(touch.clientX, touch.clientY);
        if (el && el.dataset.row !== undefined) {
          onCellDragEnter(+el.dataset.row, +el.dataset.col);
        }
      }, {passive: false});

      board.appendChild(cell);
    }
  }
}

function renderCell(r, c) {
  const cell = document.querySelector(`.cell[data-row="${r}"][data-col="${c}"]`);
  if (!cell) return;

  cell.innerHTML = '';
  cell.classList.remove('conflict');

  const state = cellState(r, c);
  if (state === 'x') {
    const span = document.createElement('span');
    span.className = 'x-mark';
    span.textContent = '\u00d7';
    cell.appendChild(span);
  } else if (state === 'queen') {
    const span = document.createElement('span');
    span.className = 'queen-mark';
    span.textContent = '\u265B';
    cell.appendChild(span);
  }
}

function renderAll() {
  for (let r = 0; r < size; r++)
    for (let c = 0; c < size; c++)
      renderCell(r, c);
  highlightConflicts();
  updateProgress();
}

// ============================================================
// CLICK / DRAG HANDLING
// ============================================================
function onCellMouseDown(r, c) {
  if (gameWon) return;
  ensureTimerRunning();

  const state = cellState(r, c);
  if (state === 'empty') {
    // Place manual X, start drag
    const snap = snapshotCells([[r, c]]);
    manualX[r][c] = true;
    history.push({snap, dragSnap: null});
    isDragging = true;
    dragCells = [[r, c]];
  } else if (state === 'x') {
    // Promote to queen (with auto-X)
    const cells = affectedCells(r, c);
    const snap = snapshotCells(cells);
    queens[r][c] = true;
    manualX[r][c] = false;
    if (document.getElementById('chk-autox').checked) {
      const key = r + ',' + c;
      for (const [rr, cc] of cells) {
        if (rr === r && cc === c) continue;
        if (!queens[rr][cc]) autoXMap[rr][cc].add(key);
      }
    }
    history.push({snap, dragSnap: null});
    isDragging = false;
  } else if (state === 'queen') {
    // Remove queen and its auto-X marks
    const cells = affectedCells(r, c);
    const snap = snapshotCells(cells);
    const key = r + ',' + c;
    queens[r][c] = false;
    for (const [rr, cc] of cells) {
      autoXMap[rr][cc].delete(key);
    }
    history.push({snap, dragSnap: null});
    isDragging = false;
  }

  renderAll();
  checkWin();
}

function onCellDragEnter(r, c) {
  if (gameWon || !isDragging) return;
  if (cellState(r, c) !== 'empty') return;
  if (dragCells.some(([dr, dc]) => dr === r && dc === c)) return;

  // Snapshot this cell and add to drag snapshot in the current history entry
  const entry = history[history.length - 1];
  if (!entry.dragSnap) entry.dragSnap = [];
  entry.dragSnap.push({
    r, c,
    queen: queens[r][c],
    manual: manualX[r][c],
    autoX: new Set(autoXMap[r][c])
  });

  manualX[r][c] = true;
  dragCells.push([r, c]);
  renderCell(r, c);
}

function endDrag() {
  isDragging = false;
  dragCells = [];
}

// ============================================================
// UNDO
// ============================================================
function undo() {
  if (history.length === 0 || gameWon) return;
  const entry = history.pop();

  // Restore drag cells first
  if (entry.dragSnap) restoreSnapshot(entry.dragSnap);
  // Restore main action cells
  restoreSnapshot(entry.snap);

  renderAll();
}

// ============================================================
// CONFLICT DETECTION
// ============================================================
function getQueenList() {
  const list = [];
  for (let r = 0; r < size; r++)
    for (let c = 0; c < size; c++)
      if (queens[r][c]) list.push({r, c});
  return list;
}

function findConflicts() {
  const qlist = getQueenList();
  const conflicted = new Set();

  for (let i = 0; i < qlist.length; i++) {
    for (let j = i + 1; j < qlist.length; j++) {
      const a = qlist[i], b = qlist[j];
      let conflict = false;
      if (a.r === b.r) conflict = true;
      if (a.c === b.c) conflict = true;
      if (puzzle.regions[a.r][a.c] === puzzle.regions[b.r][b.c]) conflict = true;
      if (Math.abs(a.r - b.r) <= 1 && Math.abs(a.c - b.c) <= 1) conflict = true;
      if (conflict) {
        conflicted.add(a.r + ',' + a.c);
        conflicted.add(b.r + ',' + b.c);
      }
    }
  }
  return conflicted;
}

function highlightConflicts() {
  const conflicts = findConflicts();
  for (let r = 0; r < size; r++) {
    for (let c = 0; c < size; c++) {
      const cell = document.querySelector(`.cell[data-row="${r}"][data-col="${c}"]`);
      if (cell) {
        if (queens[r][c] && conflicts.has(r + ',' + c)) {
          cell.classList.add('conflict');
        } else {
          cell.classList.remove('conflict');
        }
      }
    }
  }
}

// ============================================================
// WIN DETECTION
// ============================================================
function checkWin() {
  const qlist = getQueenList();
  if (qlist.length !== size) return;
  if (findConflicts().size > 0) return;

  const rows = new Set(), cols = new Set(), regions = new Set();
  for (const q of qlist) {
    rows.add(q.r);
    cols.add(q.c);
    regions.add(puzzle.regions[q.r][q.c]);
  }

  if (rows.size === size && cols.size === size && regions.size === size) {
    gameWon = true;
    stopTimer();
    document.getElementById('win-time').textContent = `Time: ${formatTime(elapsed)}`;
    setTimeout(() => {
      document.getElementById('win-overlay').classList.add('show');
    }, 300);
  }
}

// ============================================================
// TIMER
// ============================================================
function ensureTimerRunning() {
  if (timerStart === null) {
    timerStart = Date.now() - elapsed;
    timerInterval = setInterval(() => {
      elapsed = Date.now() - timerStart;
      updateTimerDisplay();
    }, 200);
  }
}

function stopTimer() {
  if (timerInterval) {
    clearInterval(timerInterval);
    timerInterval = null;
  }
}

function resetBoard() {
  loadPuzzle(puzzle);
}

function updateTimerDisplay() {
  document.getElementById('timer').textContent = formatTime(elapsed);
}

function formatTime(ms) {
  const totalSec = Math.floor(ms / 1000);
  const min = Math.floor(totalSec / 60);
  const sec = totalSec % 60;
  return min + ':' + String(sec).padStart(2, '0');
}

// ============================================================
// PROGRESS DISPLAY
// ============================================================
function updateProgress() {
  const queenCount = getQueenList().length;
  const container = document.getElementById('progress');
  container.innerHTML = '';

  // Filled circles = queens still in the "bank" (not yet placed on board)
  // Empty circles  = queens moved from bar to the play area
  const filledCount = Math.max(0, size - queenCount);
  const emptyCount = size - filledCount; // capped at size

  for (let i = 0; i < filledCount; i++) {
    const token = document.createElement('div');
    token.className = 'queen-token filled';
    token.textContent = '\u265B';
    container.appendChild(token);
  }

  for (let i = 0; i < emptyCount; i++) {
    const token = document.createElement('div');
    token.className = 'queen-token empty';
    container.appendChild(token);
  }
}

// ============================================================
// START
// ============================================================
init();
</script>

