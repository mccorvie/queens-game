    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 10px 30px;
    font-size: 1.1rem;
    cursor: pointer;
  }

  .win-box button:hover { background: #6a5acd; }

  .progress {
    margin-top: 10px;
    display: flex;
    gap: 6px;
    justify-content: center;
    flex-wrap: wrap;
    align-items: center;
    min-height: 42px;
  }

  .queen-token {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 2px solid #7b68ee;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    transition: background 0.2s, color 0.2s;
  }

  .queen-token.filled {
    background: transparent;
    color: #7b68ee;
  }

  .queen-token.empty {
    background: transparent;
  }

  @media (max-width: 600px) {
    .cell { width: 42px; height: 42px; font-size: 1.2rem; }
    .cell .queen-mark { font-size: 1.3rem; }
    .cell .x-mark { font-size: 0.9rem; }
    h1 { font-size: 1.4rem; }
    .queen-token { width: 26px; height: 26px; font-size: 0.9rem; }
  }
</style>
