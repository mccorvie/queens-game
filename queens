<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Queens Puzzle</title>
<script>
  fetch('googletag.html')
    .then(r => r.text())
    .then(html => {
      const tmp = document.createElement('div');
      tmp.innerHTML = html;
      for (const script of tmp.querySelectorAll('script')) {
        const s = document.createElement('script');
        if (script.src) { s.src = script.src; s.async = script.async; }
        else { s.textContent = script.textContent; }
        document.head.appendChild(s);
      }
    })
    .catch(() => {});
</script>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: #1a1a2e;
    color: #eee;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 100vh;
    padding: 20px;
    user-select: none;
    -webkit-user-select: none;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 4px;
    letter-spacing: 2px;
  }

  .subtitle {
    color: #aaa;
    font-size: 0.9rem;
    margin-bottom: 16px;
  }

  .toolbar {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .toolbar button {
    background: #2d2d5e;
    color: #eee;
    border: 1px solid #444;
    border-radius: 8px;
    padding: 8px 18px;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.15s;
  }

  .toolbar button:hover { background: #3d3d7e; }
  .toolbar button:active { background: #4d4d9e; }

  .toolbar .toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.95rem;
  }

  .toolbar .toggle input[type="checkbox"] {
    width: 18px;
    height: 18px;
    accent-color: #7b68ee;
    cursor: pointer;
  }

  .timer {
    font-size: 1.4rem;
    font-variant-numeric: tabular-nums;
    background: #2d2d5e;
    padding: 6px 16px;
    border-radius: 8px;
    min-width: 90px;
    text-align: center;
  }

  .puzzle-selector {
    margin-bottom: 12px;
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .puzzle-selector select {
    background: #2d2d5e;
    color: #eee;
    border: 1px solid #444;
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 0.95rem;
    cursor: pointer;
  }

  .puzzle-selector button {
    background: #2d2d5e;
    color: #eee;
    border: 1px solid #444;
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 1.2rem;
    cursor: pointer;
    line-height: 1;
  }

  .puzzle-selector button:hover { background: #3d3d7e; }

  .board-container {
    position: relative;
  }

  .board {
    display: grid;
    gap: 0;
    border: 3px solid #333;
    border-radius: 4px;
    overflow: hidden;
  }

  .cell {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    cursor: pointer;
    position: relative;
    transition: filter 0.1s;
    border: 1px solid rgba(0,0,0,0.15);
  }

  .cell:hover { filter: brightness(1.1); }

  .cell .x-mark {
    font-size: 1.2rem;
    font-weight: bold;
    color: rgba(0,0,0,0.55);
    pointer-events: none;
  }

  .cell .queen-mark {
    font-size: 1.8rem;
